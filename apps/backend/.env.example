# App Config
DEBUG=true
SECRET_KEY=generate-a-secure-secret-key-at-least-32-chars-long
ENABLE_RBAC=true

# Database
# For local dev: postgresql+asyncpg://user:pass@localhost:5432/noir
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/noir

# Redis
REDIS_URL=redis://redis:6379/0

# Supabase (for JWT validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Email (Postmark/SendGrid/SMTP)
POSTMARK_API_TOKEN=your-token
DEFAULT_FROM_EMAIL=info@noir.hr

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost
